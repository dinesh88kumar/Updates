Future<dynamic> getImage(String image) async {
  var temp;
  Reference storageref = await FirebaseStorage.instance
      .refFromURL('gs://foodie-v1-f6303.appspot.com/');

  await storageref
      .child(image)
      .getData(1024 * 1024)
      .then((value) => temp = value);
  return MemoryImage(
    temp,
  );
}

